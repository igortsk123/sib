# ──────────────────────────────────────────────────────────────────────
# sib — Агрегатор/распознавание гарантийных писем ДМС — env config
# Скопируй в .env.local (НЕ коммитится) и заполни реальными значениями.
# ──────────────────────────────────────────────────────────────────────

# --- PostgreSQL ---
DATABASE_URL=postgresql://user:password@localhost:5432/sib

# --- Яндекс.Почта OAuth (XOAUTH2: IMAP-забор входящих + SMTP-отправка) ---
# Тестовый ящик-источник: клиника пересылает сюда гарантийные письма, продукт забирает по IMAP.
YANDEX_MAIL_USER=palmarius.ru@yandex.ru
YANDEX_MAIL_FROM=palmarius.ru@yandex.ru
YANDEX_IMAP_HOST=imap.yandex.ru
YANDEX_IMAP_PORT=993
YANDEX_SMTP_HOST=smtp.yandex.ru
YANDEX_SMTP_PORT=465
YANDEX_OAUTH_CLIENT_ID=your_client_id
YANDEX_OAUTH_CLIENT_SECRET=your_client_secret
YANDEX_OAUTH_REFRESH_TOKEN=your_refresh_token
# опц. готовый access-токен (обычно берётся авто-refresh'ем по refresh-токену)
YANDEX_OAUTH_TOKEN=

# --- OpenAI (LLM-распознавание сложных писем; прокси обязателен из РФ) ---
OPENAI_BASE_URL=http://proxy-host/gpt
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-5.4-mini

# --- Inngest (durable jobs / ретраи внешних вызовов) ---
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
